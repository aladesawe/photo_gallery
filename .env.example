# Copy this file to .env and replace placeholder values with your own.

COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=your-cosmos-database-name
COSMOS_CONTAINER=your-cosmos-container-name

AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONTAINER_NAME=your-private-blob-container-name
BLOB_SAS_TTL_MINUTES=30

# Optional frontend API URL if you need to override the default relative path.
# REACT_APP_API_URL=http://localhost:7071/api
